      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Group by companyId, collect all job titles per company\nconst companyMap = {};\nfor (const item of items) {\n  const id = item.json.companyId || item.json.companyName;\n  if (!companyMap[id]) {\n    companyMap[id] = {\n      ...item.json,\n      allJobTitles: [],\n      jobCount: 0,\n      domain: ''\n    };\n  }\n  if (item.json.jobTitle) {\n    companyMap[id].allJobTitles.push(item.json.jobTitle);\n    companyMap[id].jobCount++;\n  }\n  // Extract domain from companyUrl\n  if (item.json.companyUrl && !companyMap[id].domain) {\n    const match = item.json.companyUrl.match(/linkedin\\.com\\/company\\/([^\\/]+)/);\n    if (match) companyMap[id].linkedinSlug = match[1];\n  }\n}\n\nreturn Object.values(companyMap).map(co => ({ json: co }));"
      },
